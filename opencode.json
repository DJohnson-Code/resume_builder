{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "ls *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "poetry install --no-root": "allow",
      "poetry run pytest *": "allow",
      "poetry run uvicorn *": "allow",
      "poetry run alembic *": "allow",
      "rm *": "deny",
      "git push*": "deny"
    }
  },
  "agent": {
    "build": {
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "poetry install --no-root": "allow",
          "poetry run pytest *": "allow",
          "poetry run uvicorn *": "allow",
          "poetry run alembic *": "allow",
          "rm *": "deny",
          "git push*": "deny"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  }
}